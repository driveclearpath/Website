# Netlify Functions env vars — configure these in the Netlify dashboard for production.
# For local dev with `netlify dev`, create a .env file with the same keys.

# Supabase (shared ClearPath instance — same URL/key as OS and Voice)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Claude (Anthropic)
ANTHROPIC_API_KEY=

# Resend (email notifications)
RESEND_API_KEY=
INTAKE_NOTIFY_EMAIL=info@driveclearpath.com
INTAKE_NOTIFY_FROM=intake@driveclearpath.com

# Optional — cap on AI turns per intake (safety)
MAX_INTAKE_TURNS=40
